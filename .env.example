# Firebase Configuration
# Get these from Firebase Console > Project Settings > Your apps > Web app config
VITE_FIREBASE_API_KEY=AIzaSyD1234567890abcdefghijklmnopqrst
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcd

# Google Maps API Key
# Get this from Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=AIzaSyD1234567890abcdefghijklmnopqrst

# Admin Code (for admin panel access)
VITE_ADMIN_CODE=YourSecureAdminCode
