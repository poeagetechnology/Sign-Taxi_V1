rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isAdmin() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'admin';
    }

    function isDriver() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'driver';
    }

    function isUser() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'user';
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Allow any authenticated user to read user profiles.
      // This prevents recursion / permission-denied in login + profile lookups.
      allow read: if isSignedIn();

      // Owner can update their own doc
      // Admin can update any doc
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());

      // Allow create during registration (auth uid must match doc id)
      allow create: if isSignedIn() && isOwner(userId);

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ─── Drivers ────────────────────────────────────────────────────────────
    match /drivers/{driverId} {
      // Any authenticated user can read driver profiles (for admin + passenger views)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(driverId);
      allow update: if isSignedIn() && (isOwner(driverId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Driver Locations ───────────────────────────────────────────────────
    match /driver_locations/{driverId} {
      // Drivers write their own location
      allow write: if isSignedIn() && isOwner(driverId);

      // Any authenticated user can read locations (passengers need to see drivers on map)
      allow read: if isSignedIn();
    }

    // ─── Rides ──────────────────────────────────────────────────────────────
    match /rides/{rideId} {
      // Admin can do everything
      allow read, write: if isAdmin();

      // Authenticated user can create own rides
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // User can read/update their own rides
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;

      // All users can read completed rides (to see driver ratings)
      allow read: if isSignedIn() && resource.data.status == 'completed';

      // Driver can read rides:
      // 1. Where they are assigned (driverId matches)
      // 2. Where ride is requested/searching/cancelled and driver is currentDriverId (in queue)
      allow read: if isDriver() && (
        resource.data.driverId == request.auth.uid ||
        (resource.data.currentDriverId == request.auth.uid &&
         (resource.data.status == 'requested' || resource.data.status == 'searching' || resource.data.status == 'cancelled'))
      );

      // Driver can update rides:
      // 1. Where they are already assigned (driverId matches)
      // 2. Where they are current driver accepting offer (from requested/searching or cancelled status)
      // 3. Where they are current driver rejecting offer (clearing currentDriverId)
      allow update: if isDriver() && (
        resource.data.driverId == request.auth.uid ||
        (resource.data.currentDriverId == request.auth.uid &&
         (resource.data.status == 'requested' || resource.data.status == 'searching' || resource.data.status == 'cancelled') &&
         (
           // Accept: setting status to accepted and driverId
           (request.resource.data.status == 'accepted' &&
            request.resource.data.driverId == request.auth.uid) ||
           // Reject: clearing currentDriverId
           request.resource.data.currentDriverId == null
         )
        )
      );
    }

    // ─── Driver Ratings ────────────────────────────────────────────────────
    match /driver_ratings/{ratingId} {
      // Anyone can read ratings
      allow read: if isSignedIn();

      // Users can create ratings for completed rides
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Users can update their own ratings
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Reviews (Public Landing Page) ──────────────────────────────────────
    match /reviews/{reviewId} {
      // Anyone can read reviews (for public display on landing page)
      allow read: if true;

      // Anyone (authenticated or not) can create a review
      allow create: if request.resource.data.name != null && request.resource.data.email != null && request.resource.data.text != null && request.resource.data.rating != null && request.resource.data.timestamp != null;

      // Admin can delete reviews
      allow delete: if isAdmin();
    }
  }
}
