rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isAdmin() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'admin';
    }

    function isDriver() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'driver';
    }

    function isUser() {
      return isSignedIn() && getUserData() != null && getUserData().role == 'user';
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Allow any authenticated user to read user profiles.
      // This prevents recursion / permission-denied in login + profile lookups.
      allow read: if isSignedIn();

      // Owner can update their own doc
      // Admin can update any doc
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());

      // Allow create during registration (auth uid must match doc id)
      allow create: if isSignedIn() && isOwner(userId);

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ─── Drivers ────────────────────────────────────────────────────────────
    match /drivers/{driverId} {
      // Any authenticated user can read driver profiles (for admin + passenger views)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(driverId);
      allow update: if isSignedIn() && (isOwner(driverId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Driver Locations ───────────────────────────────────────────────────
    match /driver_locations/{driverId} {
      // Drivers write their own location
      allow write: if isSignedIn() && isOwner(driverId);

      // Any authenticated user can read locations (passengers need to see drivers on map)
      allow read: if isSignedIn();
    }

    // ─── Rides ──────────────────────────────────────────────────────────────
    match /rides/{rideId} {
      // Admin can do everything
      allow read, write: if isAdmin();

      // Authenticated user can create own rides
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // User can read/update their own rides
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Driver can read rides:
      // 1. Where they are assigned (driverId matches)
      // 2. Where ride is searching and driver is in dispatch queue
      allow read: if isDriver() && (
        resource.data.driverId == request.auth.uid ||
        (resource.data.status == 'searching' && 
         resource.data.dispatchQueue.exists() &&
         resource.data.dispatchQueue.size() > 0)
      );

      // Driver can update rides:
      // 1. They are assigned to
      // 2. For dispatch status updates
      allow update: if isDriver() && (
        resource.data.driverId == request.auth.uid ||
        resource.data.status in ['searching', 'requested']
      );
    }

    // ─── Dispatch Requests ──────────────────────────────────────────────────
    // Track individual dispatch attempts to drivers
    match /dispatch_requests/{requestId} {
      // Admin can read all
      allow read: if isAdmin();

      // Drivers can read their own requests
      allow read: if isDriver() && resource.data.driverId == request.auth.uid;

      // System (authenticated users) can create dispatch requests
      allow create: if isSignedIn();

      // Drivers can update their response (accept/reject)
      allow update: if isDriver() && resource.data.driverId == request.auth.uid &&
        request.resource.data.response in ['accepted', 'rejected'];
    }

    // ─── Driver Ratings ────────────────────────────────────────────────────
    match /driver_ratings/{ratingId} {
      // Anyone can read ratings
      allow read: if isSignedIn();

      // Users can create ratings for completed rides
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;

      // Users can update their own ratings
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
